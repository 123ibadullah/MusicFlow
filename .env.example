# -----------------------------------------------
# MusicFlow — Root .env
# Copy this file to .env and fill in your values.
# The backend loads this file automatically on startup.
# -----------------------------------------------

# Server
PORT=4002
NODE_ENV=development

# MongoDB
# Local:  mongodb://localhost:27017/musicflow
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/musicflow
MONGODB_URI=mongodb://localhost:27017/musicflow

# JWT — pick any long random string
JWT_SECRET=change_me_to_a_long_random_secret

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis (optional — caching)
# Set REDIS_ENABLED=false to disable entirely (no Redis install required)
REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379

# CORS (optional — defaults to localhost/127.0.0.1 dev origins in server.js)
# CORS_ORIGIN=http://localhost:5000

# Loop Diagnosis Engine
LOOP_DIAGNOSIS_ENABLED=true
LOOP_REPLAY_THRESHOLD=<number_of_replays_threshold>
LOOP_TIME_WINDOW_MINUTES=<minutes_for_loop_window>
LOOP_COOLDOWN_MINUTES=<minutes_to_pause_after_intervention>
LOOP_COOLDOWN_MINUTES_DEV=<development_only_cooldown_minutes_override>
LOOP_LATE_NIGHT_START=<hour_0_to_23>
LOOP_LATE_NIGHT_END=<hour_0_to_23>
LOOP_LATE_NIGHT_THRESHOLD=<late_night_threshold>
LOOP_INTERVENTION_EXPIRY_SECONDS=<seconds_before_ignored>
LOOP_FATIGUE_SOFT_MINUTES=<soft_fatigue_threshold_minutes>
LOOP_FATIGUE_HARD_MINUTES=<high_fatigue_threshold_minutes>
LOOP_SESSION_TRIGGER_MINUTES=<continuous_listening_trigger_minutes>
LOOP_LATE_NIGHT_SESSION_TRIGGER_MINUTES=<late_night_listening_trigger_minutes>
LOOP_SNOOZE_MINUTES=<wellbeing_popup_snooze_minutes>
LOOP_DISMISSAL_LOOKBACK_DAYS=<days_for_behavior_lookback>
LOOP_STAGNATION_WINDOW_HOURS=<hours_for_genre_stagnation_window>
LLM_PROVIDER=<openai_or_anthropic>
LLM_API_KEY=<llm_provider_api_key>
LLM_MODEL=<llm_model_name>
LLM_TIMEOUT_MS=<llm_timeout_milliseconds>
LLM_MAX_CANDIDATES=<max_candidate_songs_for_llm>
