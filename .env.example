# -----------------------------------------------
# MusicFlow — Root .env
# Copy this file to .env and fill in your values.
# The backend loads this file automatically on startup.
# -----------------------------------------------

# Server
PORT=4002
NODE_ENV=development

# MongoDB
# Local:  mongodb://localhost:27017/musicflow
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/musicflow
MONGODB_URI=mongodb://localhost:27017/musicflow

# JWT — pick any long random string
JWT_SECRET=change_me_to_a_long_random_secret

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis (optional — caching)
# Set REDIS_ENABLED=false to disable entirely (no Redis install required)
REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379

# CORS (optional — defaults to localhost/127.0.0.1 dev origins in server.js)
# CORS_ORIGIN=http://localhost:5000

# Loop Diagnosis Engine
LOOP_DIAGNOSIS_ENABLED=true
LOOP_REPLAY_THRESHOLD=3
LOOP_TIME_WINDOW_MINUTES=30
LOOP_COOLDOWN_MINUTES=20
LOOP_COOLDOWN_MINUTES_DEV=5
LOOP_LATE_NIGHT_START=22
LOOP_LATE_NIGHT_END=6
LOOP_LATE_NIGHT_THRESHOLD=5
LOOP_INTERVENTION_EXPIRY_SECONDS=7200
LOOP_FATIGUE_SOFT_MINUTES=45
LOOP_FATIGUE_HARD_MINUTES=90
LOOP_SESSION_TRIGGER_MINUTES=60
LOOP_LATE_NIGHT_SESSION_TRIGGER_MINUTES=30
LOOP_SNOOZE_MINUTES=20
LOOP_DISMISSAL_LOOKBACK_DAYS=7
LOOP_STAGNATION_WINDOW_HOURS=8
# LLM (OpenRouter)
LLM_PROVIDER=openrouter
LLM_API_KEY=your_openrouter_api_key
LLM_MODEL=openrouter/auto
LLM_TIMEOUT_MS=8000
LLM_MAX_CANDIDATES=20
