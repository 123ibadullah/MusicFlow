modules = ["nodejs-20", "web", "python-3.11"]
[agent]
expertMode = true
integrations = ["github:1.0.0"]

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "8000"
MONGODB_URI = "mongodb://127.0.0.1:27017/musicflow"
REDIS_ENABLED = "false"
NODE_ENV = "development"
CORS_ORIGIN = "*"
VITE_API_URL = "http://localhost:8000"
JWT_SECRET = "musicflow_dev_jwt_secret_2024"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start-backend.sh"
waitForPort = 8000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd MusicWebApp && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["bash", "start-backend.sh"]
build = ["bash", "-c", "cd MusicWebApp && npm run build && mkdir -p Backend/client-dist && cp -r MusicWebApp/dist/* Backend/client-dist/"]
