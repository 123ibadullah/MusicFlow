# Client (Vite) — frontend env
# Copy to client/.env

# Leave empty when using the built-in Vite proxy (recommended for local dev).
# The proxy in vite.config.js forwards /api calls to http://localhost:4002.
# Only set this if you're NOT using the proxy (e.g. a remote backend).
VITE_API_URL=
VITE_LOOP_DIAGNOSIS_ENABLED=<true_or_false>
# Optional: auto-dismiss popup after this many ms (5000–600000). Default 120000 matches server LOOP_INTERVENTION_EXPIRY_SECONDS.
# VITE_LOOP_INTERVENTION_EXPIRY_MS=120000
